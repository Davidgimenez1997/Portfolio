{
  "name": "portfolio",
  "version": "2.1.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-analytics-config.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/generate-analytics-config.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "node dist/portfolio/server/server.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "release:check": "npm run sitemap && npm test -- --watch=false && npm run build"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "npm@11.6.0",
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "piscina": "5.2.0",
    "vite": "7.3.5"
  },
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "@fortawesome/angular-fontawesome": "^5.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.19",
    "jest": "^30.2.0",
    "jest-preset-angular": "^16.2.0",
    "jsdom": "^27.1.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
