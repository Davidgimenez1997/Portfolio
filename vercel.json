{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/ssr.mjs": {
      "includeFiles": "dist/portfolio/**"
    }
  },
  "headers": [
    {
      "source": "/:file((?:main|polyfills|styles)-.*\\.(?:js|css)|chunk-.*\\.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "www.davidgimenezrodriguez.com" }],
      "headers": {
        "Location": "https://davidgimenezrodriguez.com/$1"
      },
      "status": 308
    },
    {
      "src": "/cv/cv_enero_2024\\.pdf",
      "headers": {
        "Location": "/cv/david-gimenez-rodriguez-senior-frontend-engineer-cv.pdf"
      },
      "status": 308
    },
    {
      "src": "/",
      "headers": {
        "Location": "/es"
      },
      "status": 308
    },
    {
      "src": "/(about|projects|experience|education|contact|404)",
      "headers": {
        "Location": "/es/$1"
      },
      "status": 308
    },
    {
      "src": "/projects/(.*)",
      "headers": {
        "Location": "/es/projects/$1"
      },
      "status": 308
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
        "Cross-Origin-Opener-Policy": "same-origin",
        "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/ssr.mjs" }
  ]
}
